DR_VIDEO_ACCESS_TTL_SECONDS=3600

# audio-api/deepgram
AUDIO_DEEPGRAM_PORT=3000
AUDIO_DEEPGRAM_API_KEY=
AUDIO_DEEPGRAM_BASE_URL=http://audio-deepgram:3000

# audio-api/vosk
AUDIO_VOSK_PORT=3009
AUDIO_VOSK_BASE_URL=http://audio-vosk:3009

# dr-app internal transcription providers
DEEPGRAM_BASE_URL=http://audio-deepgram:3000
VOSK_BASE_URL=http://audio-vosk:3009

# transcription-hub (centralized transcripts DB)
TRANSCRIPTION_DB_NAME=transcriptions
TRANSCRIPTION_DB_USER=transcription
TRANSCRIPTION_DB_PASSWORD=transcription_change_me
TRANSCRIPTION_HUB_PORT=3030
TRANSCRIPTION_HUB_BASE_URL=http://transcription-hub:3030
TRANSCRIPTION_HUB_DATABASE_URL=postgresql://transcription:transcription_change_me@transcription-db:5432/transcriptions
TRANSCRIPTION_HUB_API_KEY=change-me

# dr-app transcription fetch mode
TRANSCRIPTION_FETCH_MODE=hub-first

# backups
BACKUP_DIR=/root/Democracy Routes/backups

# dr-matching
DR_MATCHING_PORT=3002
DR_MATCHING_BASE_URL=http://dr-matching:3002
DR_MATCHING_API_KEY=change-me

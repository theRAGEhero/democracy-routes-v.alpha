# Public entrypoint
APP_DOMAIN=democracyroutes.local
PROXY_HTTP_PORT=8088

# dr-app runtime
DR_APP_PORT=3015
DR_APP_DATABASE_URL=file:/data/dev.db
DEMOCRACYROUTES_CALL_BASE_URL=/video
APP_BASE_URL=http://localhost:8088
NEXTAUTH_URL=http://localhost:8088
NEXTAUTH_SECRET=change-me

# dr-app admin/auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
WORKFLOW_API_KEY=change-me

# External integrations (dr-app)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Democracy Routes <no-reply@example.com>"
IMAP_HOST=
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=
IMAP_PASS=
ANALYZE_TABLES_API_URL=http://dr-thinker:3001
ANALYZE_TABLES_API_KEY=change-me
DR_THINKER_PORT=3001
GEMINI_API_KEY=
OLLAMA_API_URL=http://ollama:11434
OLLAMA_MODEL=deepseek-r1:1.5b
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
LIVE_BRIDGE_BASE_URL=
LIVE_BRIDGE_WS_URL=
LIVE_BRIDGE_API_KEY=

# dr-video
DR_VIDEO_PORT=3020
DR_VIDEO_HOST=0.0.0.0
DR_VIDEO_ANNOUNCED_IP=
DR_VIDEO_DEEPGRAM_API_KEY=
DR_VIDEO_ACCESS_SECRET=change-me

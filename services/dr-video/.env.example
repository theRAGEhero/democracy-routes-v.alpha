PORT=3020
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3020

# Leave empty for local testing.
# For HTTPS/public deployments, set a public IP or hostname.
ANNOUNCED_IP=84.247.128.203
RTC_MIN_PORT=41000
RTC_MAX_PORT=41100

# Recording chunks will be stored under this directory.
RECORDINGS_DIR=./recordings
AUTO_RECORD_ON_JOIN=true
LOG_DIR=./logs
LOG_FILE=dr-video.log
LOG_LEVEL=info
LOG_MAX_BYTES=10485760
LOG_MAX_FILES=5
# Extra verbose trace for recording + transcription pipeline.
REC_TRANS_TRACE=true

# Deepgram live transcription (disabled if API key missing)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_INTERIM_RESULTS=true
DEEPGRAM_PUNCTUATE=true
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_DIARIZE=true
DEEPGRAM_UTTERANCES=true
DEEPGRAM_KEEPALIVE_MS=5000
